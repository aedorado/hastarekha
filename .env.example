# =============================================================================
# HastaRekhā Databank — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase publishable key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Optional: Vercel Blob Storage ─────────────────────────────────────────────
# Required only if you enable server-side image uploads via @vercel/blob.
# Get from: https://vercel.com/dashboard → Storage → Blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...